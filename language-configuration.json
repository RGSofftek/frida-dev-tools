{
  "comments": {
    "lineComment": "##"
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "<<<",
      "close": ">>>"
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*#%region\\b",
      "end": "^\\s*#%endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([A-Za-z_][A-Za-z0-9_]*\\+\\+)|((?:<<<[^>\\r\\n]+>>>|<<[^>\\r\\n]+>>|\\{[^}\\r\\n]+\\}))|([^\\s\\\"'`~!@#%^&*()\\-=+\\[\\]{}\\\\|;:,./<>?]+)"
}
